{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cuaderno de seguimiento",
  "version": "1.1.0",
  "identifier": "com.manugandini.cuadernoseguimiento",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cuaderno de seguimiento",
        "width": 1100,
        "height": 750,
        "minWidth": 720,
        "minHeight": 480
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
